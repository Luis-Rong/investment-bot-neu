# Copy this file to `.env` and fill in the keys you need.
# The app picks the provider from LLM_PROVIDER / LLM_MODEL (see llm/model.py).

# --- LLM provider selection ---
# Format: "<provider>:<model>", e.g.
#   google_genai:gemini-2.5-flash
#   google_genai:gemini-3.1-flash-lite   (higher free-tier quota, good for eval runs)
#   anthropic:claude-sonnet-5
#   openai:gpt-4o-mini
LLM_MODEL=google_genai:gemini-2.5-flash

# --- API keys (only set the one matching your provider) ---
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- IBM watsonx (optional) ---
WATSONX_APIKEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- Data source ---
# Off by default: the app loads the committed snapshot (data/universe_snapshot.json)
# so it works offline and on hosts where Yahoo blocks datacenter IPs. Set to 1 for
# fresh live yfinance metrics locally (regenerate the snapshot: python -m data_sources.snapshot).
USE_LIVE_DATA=
